---
import { getCollection } from "astro:content";
import BrandMark from "../components/BrandMark.astro";
import FeaturedPostCard from "../components/FeaturedPostCard.astro";
import Layout from "../components/Layout.astro";

const posts = (await getCollection("blog"))
  .filter((post) => post.data.published !== false)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const featuredPosts = posts.slice(0, 2);
const morePosts = posts.slice(2, 5);
---

<Layout title="Bunker Brew" description="Underground beer. Built simple. Blogg med batcher, bryggedager og notater.">
  <main id="main-content" tabindex="-1" class="container-shell py-8 sm:py-10">
    <section class="mb-10 rounded-[1.75rem] bg-brew-card/40 px-6 py-6 backdrop-blur-xl sm:px-8 sm:py-7">
      <div class="grid gap-6 lg:grid-cols-[auto,minmax(0,1fr)] lg:items-center">
        <div class="flex h-28 w-24 items-center justify-center text-brew-amber">
          <BrandMark size="lg" />
        </div>

        <div>
          <span class="section-kicker">Bunker Brew</span>
          <h1 class="mt-4 font-headline text-4xl font-bold leading-none text-brew-text sm:text-5xl">
            To karer. Ett brygg av gangen.
          </h1>
          <p class="mt-4 max-w-3xl text-sm leading-7 text-brew-text-muted sm:text-base sm:leading-8">
            Vi brygger store deler av vinteren i en ekte bunker. Resten av året flytter vi bryggingen til garasjen eller terrassen. Her deler vi oppskrifter, prosess, feil, justeringer og små seire fra bryggene våre.
          </p>

          <div class="mt-5 flex flex-wrap gap-3">
            <span class="rounded-full border border-brew-border bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-brew-text-muted">Vinter: bunker</span>
            <span class="rounded-full border border-brew-border bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-brew-text-muted">Sommer: garasje og terrasse</span>
            <span class="rounded-full border border-brew-border bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-brew-text-muted">Fokus: ryddige brygg</span>
          </div>
        </div>
      </div>
    </section>

    <section>
      <div class="grid gap-10 md:grid-cols-2">
        {featuredPosts.map((post) => (
          <FeaturedPostCard
            href={`/blog/${post.slug}/`}
            title={post.data.title}
            summary={post.data.summary}
            pubDate={post.data.pubDate}
            category={post.data.category}
            image={post.data.image}
            aspect="video"
          />
        ))}
      </div>
    </section>

    {morePosts.length > 0 ? (
      <section class="mt-10">
        <div class="grid gap-10 sm:grid-cols-2 xl:grid-cols-3">
          {morePosts.map((post) => (
            <FeaturedPostCard
              href={`/blog/${post.slug}/`}
              title={post.data.title}
              summary={post.data.summary}
              pubDate={post.data.pubDate}
              category={post.data.category}
              image={post.data.image}
              aspect="square"
            />
          ))}
        </div>
      </section>
    ) : null}
  </main>
</Layout>
