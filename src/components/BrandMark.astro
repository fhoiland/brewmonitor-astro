---
interface Props {
  size?: "sm" | "md" | "lg";
}

const { size = "md" } = Astro.props;
const wrapperClass =
  size === "sm" ? "h-9 w-7" : size === "lg" ? "h-20 w-16" : "h-[3.2rem] w-[2.4rem]";
---

<div class:list={["flex items-center justify-center text-brew-amber", wrapperClass]}>
  <svg
    viewBox="0 0 28 36"
    aria-hidden="true"
    class="h-full w-full"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      d="M4 32V12.5C4 6.7 8.7 2 14.5 2H15.5C21.3 2 26 6.7 26 12.5V32"
      stroke="currentColor"
      stroke-width="3"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    <path
      d="M15 8V29"
      stroke="currentColor"
      stroke-width="2.4"
      stroke-linecap="round"
    />
    <path
      d="M15 10.5 10.6 8.2V12.1L15 14.2V10.5Z"
      fill="currentColor"
    />
    <path
      d="M15 16.2 10.2 13.8V17.9L15 20.1V16.2Z"
      fill="currentColor"
    />
    <path
      d="M15 22 10.6 19.8V23.7L15 25.8V22Z"
      fill="currentColor"
    />
    <path
      d="M15 10.5 19.4 8.2V12.1L15 14.2V10.5Z"
      fill="currentColor"
    />
    <path
      d="M15 16.2 19.8 13.8V17.9L15 20.1V16.2Z"
      fill="currentColor"
    />
    <path
      d="M15 22 19.4 19.8V23.7L15 25.8V22Z"
      fill="currentColor"
    />
