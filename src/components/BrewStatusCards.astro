---
import { brewStatus } from "../data/site";
---

<div class="grid gap-6 lg:grid-cols-2">
  <section class="glass-card overflow-hidden rounded-[2rem]">
    <div class="border-b border-brew-border p-6">
      <div class="mb-5 flex items-start justify-between gap-4">
        <div class="flex items-center gap-3">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-brew-red/15 text-brew-red">
            <span class="font-headline text-lg font-bold">BK</span>
          </div>
          <div>
            <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-brew-text-muted">Brygging</p>
            <h2 class="font-headline text-2xl font-bold text-brew-text">{brewStatus.kettle.title}</h2>
          </div>
        </div>
        <span class="rounded-full bg-brew-green px-3 py-1 text-xs font-semibold text-brew-dark">
          {brewStatus.kettle.mode}
        </span>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-[1.5rem] border border-brew-border bg-brew-amber-soft p-5">
          <p class="mb-2 text-xs font-semibold uppercase tracking-[0.22em] text-brew-text-muted">Nåværende temperatur</p>
          <div class="flex items-end gap-2">
            <span class="font-headline text-4xl font-bold text-brew-text">{brewStatus.kettle.currentTemperature}</span>
            <span class="pb-1 text-base font-semibold text-brew-amber">°C</span>
          </div>
        </div>

        <div class="rounded-[1.5rem] border border-brew-border bg-white/5 p-5">
          <p class="mb-2 text-xs font-semibold uppercase tracking-[0.22em] text-brew-text-muted">Status akkurat nå</p>
          <p class="font-headline text-3xl font-bold text-brew-text">{brewStatus.kettle.mode}</p>
          <p class="mt-2 text-sm text-brew-text-muted">{brewStatus.kettle.updatedLabel}</p>
        </div>
      </div>
    </div>

    <div class="grid gap-3 p-6">
      {brewStatus.kettle.rows.map((row) => (
        <div class="flex items-center justify-between gap-4 rounded-[1.25rem] border border-brew-border bg-white/[0.03] px-4 py-3">
          <span class="text-sm text-brew-text-muted">{row.label}</span>
          <span class="font-mono text-lg text-brew-text">{row.value}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="glass-card overflow-hidden rounded-[2rem]">
    <div class="border-b border-brew-border p-6">
      <div class="mb-5 flex items-start justify-between gap-4">
        <div class="flex items-center gap-3">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-brew-amber-soft text-brew-amber">
            <span class="font-headline text-lg font-bold">F</span>
          </div>
          <div>
            <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-brew-text-muted">Gjæring</p>
            <h2 class="font-headline text-2xl font-bold text-brew-text">{brewStatus.fermenter.title}</h2>
          </div>
        </div>
        <span class="rounded-full border border-brew-border bg-white/5 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-brew-text-muted">
          {brewStatus.fermenter.progress}% ferdig
        </span>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-[1.5rem] border border-brew-border bg-white/5 p-5">
          <p class="mb-2 text-xs font-semibold uppercase tracking-[0.22em] text-brew-text-muted">Aktiv batch</p>
          <p class="font-headline text-3xl font-bold text-brew-text">{brewStatus.fermenter.batch}</p>
        </div>

        <div class="rounded-[1.5rem] border border-brew-border bg-brew-amber-soft p-5">
          <p class="mb-2 text-xs font-semibold uppercase tracking-[0.22em] text-brew-text-muted">Fremdrift</p>
          <p class="mb-3 font-headline text-3xl font-bold text-brew-text">{brewStatus.fermenter.progress}%</p>
          <div class="h-2.5 overflow-hidden rounded-full bg-white/10">
            <div
              class="h-full rounded-full bg-brew-amber"
              style={`width: ${brewStatus.fermenter.progress}%`}
            />
          </div>
        </div>
      </div>
    </div>

    <div class="grid gap-3 p-6">
      {brewStatus.fermenter.rows.map((row) => (
        <div class="flex items-center justify-between gap-4 rounded-[1.25rem] border border-brew-border bg-white/[0.03] px-4 py-3">
          <span class="text-sm text-brew-text-muted">{row.label}</span>
          <span class="font-mono text-lg text-brew-text">{row.value}</span>
        </div>
      ))}
    </div>
  </section>
</div>
