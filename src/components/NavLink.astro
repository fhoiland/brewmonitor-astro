---
import { stripBase, withBase } from "../utils/paths";

interface Props {
  href: string;
  label: string;
  currentPath: string;
}

const { href, label, currentPath } = Astro.props;
const active = stripBase(currentPath) === href;
const actualHref = withBase(href);
---

<a
  href={actualHref}
  class:list={[
    "inline-flex items-center rounded-full px-4 py-2 text-sm font-semibold transition-all",
    active
      ? "bg-brew-amber text-brew-dark shadow-lg shadow-amber-500/20"
      : "text-brew-text-muted hover:bg-white/5 hover:text-brew-text",
  ]}
>
  {label}
</a>
